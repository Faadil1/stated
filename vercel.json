{
  "functions": {
    "api/upload-manifest.js": {
      "runtime": "nodejs24.x",
      "memory": 512
    }
  },
  "buildCommand": "npm install && npm ci --prefix frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
