# Frontend Configuration
#
# REQUIRED: Contract address must be set in frontend/.env.local
# (never commit .env.local to version control)

# Contract address deployed on the target network
# Examples:
#   Local Hardhat: 0xDc64a140Aa3E981100a9becA4E685f962f0cF6C9
#   Monad testnet: (set after deployment)
VITE_CONTRACT_ADDRESS=

# (Optional) Chain ID for validation
VITE_CHAIN_ID=31337
